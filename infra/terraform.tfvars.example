project_id = "your-project-id"
region     = "asia-northeast1"
image      = "asia-northeast1-docker.pkg.dev/your-project-id/redmine/redmine:latest"

# HTTP only (IP direct access)
domain = ""

# To enable HTTPS + DNS, uncomment:
# domain = "redmine.example.com"

db_tier                = "db-f1-micro"
cloudrun_cpu           = "1"
cloudrun_memory        = "512Mi"
cloudrun_max_instances = 3
warmup_schedule        = "0 8 * * 1-5"
sleep_schedule         = "0 20 * * 1-5"
